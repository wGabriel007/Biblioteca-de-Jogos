@model Biblioteca_de_Jogos.Models.Jogo
@{
    ViewData["Title"] = "Adicionar Jogo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Adicionar Jogo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label">Nome do Jogo</label>
                            <input asp-for="Nome" class="form-control" placeholder="Ex: The Last of Us" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Genero" class="form-label">Gênero</label>
                            <input asp-for="Genero" class="form-control" placeholder="Ex: Aventura, RPG, FPS" />
                            <span asp-validation-for="Genero" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="HorasParaZerar" class="form-label">Horas para Zerar</label>
                            <input asp-for="HorasParaZerar" class="form-control" type="number" min="0" />
                            <span asp-validation-for="HorasParaZerar" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FotoUrl" class="form-label">URL da Capa (opcional)</label>
                            <input asp-for="FotoUrl" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="FotoUrl" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="EstaEmprestado" class="form-check-input" />
                            <label asp-for="EstaEmprestado" class="form-check-label">Está emprestado?</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}