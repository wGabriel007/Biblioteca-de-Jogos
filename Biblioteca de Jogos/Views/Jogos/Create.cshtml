@model Biblioteca_de_Jogos.Models.Jogo
@{
    ViewData["Title"] = "Adicionar Jogo";
    var consoles           = ViewBag.Consoles as List<Biblioteca_de_Jogos.Models.Console>
                             ?? new List<Biblioteca_de_Jogos.Models.Console>();
    var consoleSelecionado = ViewBag.ConsoleSelecionado as string ?? "";
    var grupos             = consoles.GroupBy(c => c.str_Grupo);
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Adicionar Jogo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="txt_Nome" class="form-label">Nome do Jogo</label>
                            <input asp-for="txt_Nome" class="form-control"
                                   placeholder="Ex: The Last of Us" />
                            <span asp-validation-for="txt_Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="txt_Genero" class="form-label">Gênero</label>
                            <input asp-for="txt_Genero" class="form-control"
                                   placeholder="Ex: Aventura, RPG, FPS" />
                            <span asp-validation-for="txt_Genero" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="int_HorasParaZerar" class="form-label">Horas para Zerar</label>
                            <input asp-for="int_HorasParaZerar" class="form-control"
                                   type="number" min="0" />
                            <span asp-validation-for="int_HorasParaZerar" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="txt_FotoUrl" class="form-label">URL da Capa (opcional)</label>
                            <input asp-for="txt_FotoUrl" class="form-control"
                                   placeholder="https://..." />
                        </div>

                        <div class="mb-3">
                            <label asp-for="txt_Console" class="form-label">Console</label>
                            <select asp-for="txt_Console" class="form-select">
                                <option value="">Selecione o console</option>
                                @foreach (var grupo in grupos)
                                {
                                    <optgroup label="@grupo.Key">
                                        @foreach (var c in grupo)
                                        {
                                            <option value="@c.str_Nome">@c.str_Nome</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <span asp-validation-for="txt_Console" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Disponibilidade para Empréstimo</label>
                            <div class="form-check form-switch">
                                <input asp-for="bool_Disponivel" class="form-check-input"
                                       type="checkbox" role="switch" id="switchDisponivel" checked />
                                <label class="form-check-label" for="switchDisponivel">
                                    Disponível para empréstimo
                                </label>
                            </div>
                            <small class="text-muted">
                                Se desmarcado, nenhum usuário poderá solicitar este jogo.
                            </small>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary"> Salvar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}