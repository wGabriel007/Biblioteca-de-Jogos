@model Biblioteca_de_Jogos.Models.Periferico
@{
    ViewData["Title"] = "Adicionar Perifericos";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Adicionar Periférico</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Perifericos" method="post">

                        <div class="mb-3">
                            <label asp-for="txt_Nome" class="form-label">Nome do Periferico</label>
                            <input asp-for="txt_Nome" class="form-control"
                                   placeholder="Ex: Controle" />
                            <span asp-validation-for="txt_Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="txt_Estado" class="form-label">Estado</label>
                            <input asp-for="txt_Estado" class="form-control"
                                   placeholder="Ex: Usado, Novo, Quebrado" />
                            <span asp-validation-for="txt_Estado" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="txt_FotoUrl" class="form-label">Foto do periferico(opcional)</label>
                            <input asp-for="txt_FotoUrl" class="form-control"
                                   placeholder="https://..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Disponibilidade para Empréstimo</label>
                            <div class="form-check form-switch">
                                <input asp-for="bool_Disponivel_Emprestimo" class="form-check-input"
                                       type="checkbox" role="switch" id="switchDisponivel" checked />
                                <label class="form-check-label" for="switchDisponivel">
                                    Disponível para empréstimo
                                </label>
                            </div>
                        </div>
                            <div class="mb-3">
                                <label class="form-label">Disponibilidade para Venda</label>
                                <div class="form-check form-switch">
                                    <input asp-for="bool_Disponivel_Venda" class="form-check-input"
                                           type="checkbox" role="switch" id="switchDisponivel" checked />
                                    <label class="form-check-label" for="switchDisponivel">
                                        Disponível para Venda
                                    </label>
                                </div>
                            <small class="text-muted">
                                Se desmarcado, nenhum usuário poderá solicitar este periferico.
                            </small>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary"> Salvar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}