@model IEnumerable<Biblioteca_de_Jogos.Models.Jogo>
@{
    ViewData["Title"] = "Minha Biblioteca";
    var usuarioLogado  = Context.Session.GetString("UsuarioNome");
    var isAdmin        = Context.Session.GetString("IsAdmin") == "True";
    var totalPendentes = ViewBag.TotalPendentes as int? ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Biblioteca de Jogos</h2>
        <div class="d-flex gap-2 align-items-center">
            @if (isAdmin)
            {
                <span class="badge bg-danger">Admin</span>
            }
            <span class="text-muted small">👤 @usuarioLogado</span>

            <a asp-controller="Emprestimo" asp-action="Notificacoes"
               class="btn btn-outline-secondary btn-sm position-relative">
                ✉️
                @if (totalPendentes > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle
                                 badge rounded-pill bg-danger">
                        @totalPendentes
                    </span>
                }
            </a>

            <a asp-action="Create" class="btn btn-primary btn-sm">+ Adicionar Jogo</a>
            <a asp-action="Logout" asp-controller="Home" class="btn btn-outline-secondary btn-sm">Sair</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <input id="filtroNome" type="text" class="form-control"
                           placeholder="Buscar por nome..." oninput="filtrar()" />
                </div>
                <div class="col-md-3">
                    <select id="filtroConsole" class="form-select" onchange="filtrar()">
                        <option value="">Todos os consoles</option>
                        @foreach (var console in Model.Select(j => j.Console).Distinct().OrderBy(c => c))
                        {
                            <option value="@console">@console</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="filtroGenero" class="form-select" onchange="filtrar()">
                        <option value="">Todos os gêneros</option>
                        @foreach (var genero in Model.Select(j => j.Genero).Distinct().OrderBy(g => g))
                        {
                            <option value="@genero">@genero</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select id="filtroDisponivel" class="form-select" onchange="filtrar()">
                        <option value=""> Todos</option>
                        <option value="disponivel">Disponíveis</option>
                        <option value="emprestado">Emprestados</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div id="semResultados" class="alert alert-info d-none">
        Nenhum jogo encontrado com os filtros selecionados.
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4" id="listaJogos">
        @foreach (var jogo in Model)
        {
            var temPermissao = isAdmin || jogo.Dono == usuarioLogado;
            var ehDono       = jogo.Dono == usuarioLogado;

            <div class="col jogo-card"
                 data-nome="@jogo.Nome.ToLower()"
                 data-console="@jogo.Console"
                 data-genero="@jogo.Genero"
                 data-disponivel="@(jogo.EstaEmprestado ? "emprestado" : "disponivel")">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(jogo.FotoUrl))
                    {
                        <img src="@jogo.FotoUrl" class="card-img-top"
                             style="height:180px; object-fit:cover;" alt="@jogo.Nome" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@jogo.Nome</h5>
                        <p class="card-text text-muted mb-1">🎯 @jogo.Genero</p>
                        <p class="card-text text-muted mb-1">🎮 @jogo.Console</p>
                        <p class="card-text text-muted mb-1">⏱️ @jogo.HorasParaZerar horas para zerar</p>
                        <p class="card-text mb-1">👤 Dono: <strong>@jogo.Dono</strong></p>

                        @if (jogo.EstaEmprestado)
                        {
                            <span class="badge bg-warning text-dark">
                                📤 Emprestado para: @jogo.EmprestadoPara
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">✅ Disponível</span>
                        }
                    </div>
                    <div class="card-footer d-flex flex-wrap gap-2">
                        @if (temPermissao)
                        {
                            <a asp-action="Edit" asp-route-id="@jogo.Id"
                               class="btn btn-sm btn-outline-primary"> Editar</a>

                            <form asp-action="Delete" asp-route-id="@jogo.Id" method="post"
                                  onsubmit="return confirm('Remover @jogo.Nome?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                     Remover
                                </button>
                            </form>

                            @if (jogo.EstaEmprestado && ehDono)
                            {
                                <form asp-controller="Emprestimo" asp-action="Devolver" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jogoId" value="@jogo.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                         Devolvido
                                    </button>
                                </form>
                            }
                        }
                        else if (!jogo.EstaEmprestado && jogo.Dono != usuarioLogado)
                        {
                            <form asp-controller="Emprestimo" asp-action="Solicitar" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="jogoId" value="@jogo.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-info">
                                     Pedir Emprestado
                                </button>
                            </form>
                        }
                        else if (jogo.EstaEmprestado && !ehDono)
                        {
                            <span class="text-muted small align-self-center">
                                 Emprestado
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function filtrar() {
            const nome       = document.getElementById('filtroNome').value.toLowerCase();
            const console    = document.getElementById('filtroConsole').value;
            const genero     = document.getElementById('filtroGenero').value;
            const disponivel = document.getElementById('filtroDisponivel').value;

            const cards = document.querySelectorAll('.jogo-card');
            let visiveis = 0;

            cards.forEach(card => {
                const nomeMatch       = card.dataset.nome.includes(nome);
                const consoleMatch    = !console    || card.dataset.console    === console;
                const generoMatch     = !genero     || card.dataset.genero     === genero;
                const disponivelMatch = !disponivel || card.dataset.disponivel === disponivel;

                const visivel = nomeMatch && consoleMatch && generoMatch && disponivelMatch;
                card.style.display = visivel ? '' : 'none';
                if (visivel) visiveis++;
            });

            document.getElementById('semResultados').classList.toggle('d-none', visiveis > 0);
        }
    </script>
}
