@model Biblioteca_de_Jogos.Models.Jogo
@{
    ViewData["Title"] = "Editar Jogo";
    var consoles           = ViewBag.Consoles as List<Biblioteca_de_Jogos.Models.Console>
                             ?? new List<Biblioteca_de_Jogos.Models.Console>();
    var consoleSelecionado = Model.Console ?? "";
    var grupos             = consoles.GroupBy(c => c.Grupo);
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Jogo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input asp-for="Id" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label">Nome do Jogo</label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Genero" class="form-label">Gênero</label>
                            <input asp-for="Genero" class="form-control" />
                            <span asp-validation-for="Genero" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HorasParaZerar" class="form-label">Horas para Zerar</label>
                            <input asp-for="HorasParaZerar" class="form-control"
                                   type="number" min="0" />
                            <span asp-validation-for="HorasParaZerar" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FotoUrl" class="form-label">URL da Capa (opcional)</label>
                            <input asp-for="FotoUrl" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Console" class="form-label">Console</label>
                            <select asp-for="Console" class="form-select">
                                <option value="">Selecione o console</option>
                                @foreach (var grupo in grupos)
                                {
                                    <optgroup label="@grupo.Key">
                                        @foreach (var c in grupo)
                                        {
                                            <option value="@c.Nome"
                                                    selected="@(c.Nome == consoleSelecionado ? "selected" : null)">
                                                @c.Nome
                                            </option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <span asp-validation-for="Console" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="EstaEmprestado" class="form-check-input" />
                            <label asp-for="EstaEmprestado" class="form-check-label">
                                Está emprestado?
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Atualizar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
