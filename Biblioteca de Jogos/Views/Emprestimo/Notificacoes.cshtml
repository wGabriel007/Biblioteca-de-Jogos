@model IEnumerable<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>
@using Biblioteca_de_Jogos.Models
@{
    ViewData["Title"] = "Notificações";
    var pedidosRecebidos = ViewBag.PedidosRecebidos as List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>
                           ?? new List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>();
    var minhasRespostas  = ViewBag.MinhasRespostas  as List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>
                           ?? new List<Biblioteca_de_Jogos.Models.SolicitacaoEmprestimo>();
    var pedidosPerifericosRecebidos = ViewBag.PedidosPerifericosRecebidos as List<Biblioteca_de_Jogos.Models.SolicitacaoPeriferico>
                           ?? new List<Biblioteca_de_Jogos.Models.SolicitacaoPeriferico>();
    var minhasRespostasPeriferico = ViewBag.MinhasRespostasPeriferico as List<Biblioteca_de_Jogos.Models.SolicitacaoPeriferico>
                           ?? new List<Biblioteca_de_Jogos.Models.SolicitacaoPeriferico>();

    var totalPedidos   = pedidosRecebidos.Count + pedidosPerifericosRecebidos.Count;
    var totalRespostas = minhasRespostas.Count + minhasRespostasPeriferico.Count;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Notificações</h2>
        <a asp-controller="Jogos" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Voltar</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h5 class="mt-3 mb-2">Pedidos recebidos</h5>
    @if (totalPedidos == 0)
    {
        <div class="alert alert-info">Nenhum pedido pendente.</div>
    }
    else
    {
        <div class="row g-3 mb-4">

            @foreach (var s in pedidosRecebidos)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm border-warning">
                        <div class="card-body d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(s.Jogo?.txt_FotoUrl))
                            {
                                <img src="@s.Jogo.txt_FotoUrl" style="height:70px; border-radius:8px; object-fit:cover;" />
                            }
                            <div>
                                <span class="badge bg-secondary mb-1">🎮 Jogo</span>
                                <h6 class="mb-1">@s.Jogo?.txt_Nome</h6>
                                <p class="mb-1">👤 <strong>@s.str_SolicitanteNome</strong> quer pegar emprestado</p>
                                <small class="text-muted">📅 @s.ts_DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <form asp-controller="Emprestimo" asp-action="Aceitar" method="post" class="w-50">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-success w-100">✅ Aceitar</button>
                            </form>
                            <form asp-controller="Emprestimo" asp-action="Rejeitar" method="post" class="w-50">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-danger w-100">❌ Rejeitar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

            @foreach (var s in pedidosPerifericosRecebidos)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm border-warning">
                        <div class="card-body d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(s.Periferico?.txt_FotoUrl))
                            {
                                <img src="@s.Periferico.txt_FotoUrl" style="height:70px; border-radius:8px; object-fit:cover;" />
                            }
                            <div>
                                <span class="badge bg-secondary mb-1"> Periférico</span>
                                <span class="badge @(s.str_TipoSolicitacao == "Venda" ? "bg-success" : "bg-info") mb-1">
                                    @(s.str_TipoSolicitacao == "Venda" ? "💰 Venda" : "📦 Empréstimo")
                                </span>
                                <h6 class="mb-1">@s.Periferico?.txt_Nome</h6>
                                <p class="mb-1">
                                    👤 <strong>@s.str_SolicitanteNome</strong>
                                    quer @(s.str_TipoSolicitacao == "Venda" ? "comprar" : "pegar emprestado")
                                </p>
                                <small class="text-muted">📅 @s.ts_DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <form asp-controller="Emprestimo" asp-action="AceitarPeriferico" method="post" class="w-50">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-success w-100">✅ Aceitar</button>
                            </form>
                            <form asp-controller="Emprestimo" asp-action="RejeitarPeriferico" method="post" class="w-50">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-danger w-100">❌ Rejeitar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

        </div>
    }

    <hr />

    <h5 class="mt-3 mb-2">Minhas respostas</h5>
    @if (totalRespostas == 0)
    {
        <div class="alert alert-info">Nenhuma resposta nova.</div>
    }
    else
    {
        <div class="row g-3">

            @foreach (var s in minhasRespostas)
            {
                var (borda, icone, texto) = s.int_Status == (int)StatusSolicitacao.Aceito
                    ? ("border-success", "✅", "Pedido ACEITO!")
                    : ("border-danger",  "❌", "Pedido RECUSADO.");
                <div class="col-md-6">
                    <div class="card shadow-sm @borda">
                        <div class="card-body d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(s.Jogo?.txt_FotoUrl))
                            {
                                <img src="@s.Jogo.txt_FotoUrl" style="height:70px; border-radius:8px; object-fit:cover;" />
                            }
                            <div>
                                <span class="badge bg-secondary mb-1">🎮 Jogo</span>
                                <h6 class="mb-1">@s.Jogo?.txt_Nome</h6>
                                <p class="mb-1"><strong>@icone @texto</strong></p>
                                <p class="mb-1 text-muted small">👤 Dono: @s.str_DonoNome</p>
                                <small class="text-muted">📅 @s.ts_DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div class="card-footer">
                            <form asp-controller="Emprestimo" asp-action="MarcarVisualizada" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-outline-secondary w-100">Confirmar leitura</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

            @foreach (var s in minhasRespostasPeriferico)
            {
                var (borda, icone, texto) = s.int_Status == (int)StatusSolicitacao.Aceito
                    ? ("border-success", "✅", "Pedido ACEITO!")
                    : ("border-danger",  "❌", "Pedido RECUSADO.");
                <div class="col-md-6">
                    <div class="card shadow-sm @borda">
                        <div class="card-body d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrEmpty(s.Periferico?.txt_FotoUrl))
                            {
                                <img src="@s.Periferico.txt_FotoUrl" style="height:70px; border-radius:8px; object-fit:cover;" />
                            }
                            <div>
                                <span class="badge bg-secondary mb-1">🕹️ Periférico</span>
                                <span class="badge @(s.str_TipoSolicitacao == "Venda" ? "bg-success" : "bg-info") mb-1">
                                    @(s.str_TipoSolicitacao == "Venda" ? "💰 Venda" : "📦 Empréstimo")
                                </span>
                                <h6 class="mb-1">@s.Periferico?.txt_Nome</h6>
                                <p class="mb-1"><strong>@icone @texto</strong></p>
                                <p class="mb-1 text-muted small">👤 Dono: @s.str_DonoNome</p>
                                <small class="text-muted">📅 @s.ts_DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div class="card-footer">
                            <form asp-controller="Emprestimo" asp-action="MarcarVisualizadaPeriferico" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.int_Id" />
                                <button type="submit" class="btn btn-outline-secondary w-100">Confirmar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>
