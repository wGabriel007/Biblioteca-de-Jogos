@model Biblioteca_de_Jogos.Models.EsqueceuSenhaViewModel
@{ ViewData["Title"] = "Esqueceu a Senha"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; }
    .card-recuperacao { max-width: 450px; margin: 50px auto; padding: 40px; background: rgba(255,255,255,0.95); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
    .form-control { padding: 12px 15px; border-radius: 10px; border: 2px solid #e0e0e0; transition: all 0.3s ease; }
    .form-control:focus { border-color: #667eea; box-shadow: 0 0 0 0.2rem rgba(102,126,234,0.25); }
    .btn-enviar { width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 10px; color: white; font-weight: 600; font-size: 16px; transition: all 0.3s ease; }
    .btn-enviar:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102,126,234,0.4); color: white; }
</style>

<div class="card-recuperacao">
    <div class="text-center mb-4">
        <div class="mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#667eea" viewBox="0 0 24 24">
                <path d="M21.58 16.09l-1.09-7.66C20.21 6.46 18.52 5 16.53 5H7.47C5.48 5 3.79 6.46 3.51 8.43l-1.09 7.66C2.2 17.63 3.39 19 4.94 19c.68 0 1.32-.27 1.8-.75L9 16h6l2.25 2.25c.48.48 1.12.75 1.8.75 1.56 0 2.75-1.37 2.53-2.91zM11 11H9v2H8v-2H6v-1h2V8h1v2h2v1zm4-1c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm2 3c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
            </svg>
        </div>
        <h2 style="color:#667eea; font-weight:700;">Recuperar Senha</h2>
        <p class="text-muted">Informe seu e-mail para receber o código</p>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger border-radius:10px">
            <ul class="mb-0">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <li>@e.ErrorMessage</li> }
            </ul>
        </div>
    }

    <form asp-action="EsqueceuSenha" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Email" class="form-label">E-mail</label>
            <input asp-for="Email" class="form-control" placeholder="seuemail@gmail.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-enviar mt-2">Enviar Código</button>
        <div class="text-center mt-3">
            <a asp-action="Loguin" class="text-decoration-underline text-secondary small">Voltar ao login</a>
        </div>
    </form>
    <div class="text-center mt-4"><p class="text-muted small mb-0">Desenvolvido por GETIC - 2026</p></div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
