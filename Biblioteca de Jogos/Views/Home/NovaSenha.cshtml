@model Biblioteca_de_Jogos.Models.NovaSenhaViewModel
@{ ViewData["Title"] = "Nova Senha"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; }
    .card-recuperacao { max-width: 450px; margin: 50px auto; padding: 40px; background: rgba(255,255,255,0.95); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
    .form-control { padding: 12px 15px; border-radius: 10px; border: 2px solid #e0e0e0; transition: all 0.3s ease; }
    .form-control:focus { border-color: #667eea; box-shadow: 0 0 0 0.2rem rgba(102,126,234,0.25); }
    .btn-salvar { width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 10px; color: white; font-weight: 600; font-size: 16px; transition: all 0.3s ease; }
    .btn-salvar:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102,126,234,0.4); color: white; }
</style>

<div class="card-recuperacao">
    <div class="text-center mb-4">
        <div class="mb-3" style="font-size:70px;">🔒</div>
        <h2 style="color:#667eea; font-weight:700;">Nova Senha</h2>
        <p class="text-muted">Crie uma nova senha para sua conta</p>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <li>@e.ErrorMessage</li> }
            </ul>
        </div>
    }

    <form asp-action="NovaSenha" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Codigo" />
        <div class="mb-3">
            <label asp-for="NovaSenha" class="form-label">Nova Senha</label>
            <input asp-for="NovaSenha" type="password" class="form-control"
                   placeholder="Mínimo 6 caracteres" />
            <span asp-validation-for="NovaSenha" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmarSenha" class="form-label">Confirmar Senha</label>
            <input asp-for="ConfirmarSenha" type="password" class="form-control"
                   placeholder="Repita a senha" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-salvar mt-2">Salvar Nova Senha</button>
    </form>
    <div class="text-center mt-4"><p class="text-muted small mb-0">Desenvolvido por GETIC - 2026</p></div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }