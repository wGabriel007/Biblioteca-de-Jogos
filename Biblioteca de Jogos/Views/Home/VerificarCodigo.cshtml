@model Biblioteca_de_Jogos.Models.VerificarCodigoViewModel
@{ ViewData["Title"] = "Verificar Código"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; }
    .card-recuperacao { max-width: 450px; margin: 50px auto; padding: 40px; background: rgba(255,255,255,0.95); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
    .form-control { padding: 12px 15px; border-radius: 10px; border: 2px solid #e0e0e0; transition: all 0.3s ease; }
    .form-control:focus { border-color: #667eea; box-shadow: 0 0 0 0.2rem rgba(102,126,234,0.25); }
    .btn-verificar { width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 10px; color: white; font-weight: 600; font-size: 16px; transition: all 0.3s ease; }
    .btn-verificar:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102,126,234,0.4); color: white; }
</style>

<div class="card-recuperacao">
    <div class="text-center mb-4">
        <div class="mb-3" style="font-size:70px;">📧</div>
        <h2 style="color:#667eea; font-weight:700;">Verifique seu E-mail</h2>
        <p class="text-muted">Insira o código de 6 dígitos enviado para <strong>@Model.Email</strong></p>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <li>@e.ErrorMessage</li> }
            </ul>
        </div>
    }

    <form asp-action="VerificarCodigo" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Email" />
        <div class="mb-3">
            <label asp-for="Codigo" class="form-label">Código de Verificação</label>
            <input asp-for="Codigo" class="form-control text-center"
                   style="font-size:24px; letter-spacing:8px;"
                   placeholder="000000" maxlength="6" />
            <span asp-validation-for="Codigo" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-verificar mt-2">Verificar Código</button>
        <div class="text-center mt-3">
            <a asp-action="EsqueceuSenha" class="text-decoration-underline text-secondary small">Reenviar código</a>
        </div>
    </form>
    <div class="text-center mt-4"><p class="text-muted small mb-0">Desenvolvido por GETIC - 2026</p></div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }